# automation-stack/.env.example
# Copy to automation-stack/.env and fill in values.
# NEVER commit .env — it is excluded by .gitignore.
# ──────────────────────────────────────────────────

# ── n8n Authentication ────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
# Strong password required — n8n has access to all credentials
N8N_BASIC_AUTH_PASSWORD=REPLACE_ME_strong_password

# n8n encryption key — protects stored credentials at rest
# Generate: openssl rand -hex 32
# IMPORTANT: if this changes, all stored credentials become unreadable
N8N_ENCRYPTION_KEY=REPLACE_ME_32_hex_chars

# ── Cross-stack: Hermes Agent ─────────────────────
# Must match LITELLM_MASTER_KEY in ai-stack/.env
LITELLM_MASTER_KEY=sk-hermes-REPLACE_ME

# ── Paperclip (V2 — not active in V1) ────────────
# Only set when activating paperclip profile
PAPERCLIP_IMAGE=ghcr.io/aia2025/paperclip:latest
