# automation-stack/.env.example
# Copy to .env and fill in values — never commit .env
# ──────────────────────────────────────────────────

# n8n Basic Auth
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme-strong-password

# n8n Encryption Key (used for storing credentials securely)
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme-32-hex-chars

# Hermes Agent API key (same as LITELLM_MASTER_KEY in ai-stack)
LITELLM_MASTER_KEY=sk-hermes-changeme

# Paperclip (activate only when image is ready)
PAPERCLIP_IMAGE=ghcr.io/aia2025/paperclip:latest

# Notion credentials are managed inside n8n (Credentials manager),
# not via environment variables. Set them in the n8n UI after first login.
