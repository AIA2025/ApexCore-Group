# ai-stack/.env.example
# Copy to .env and fill in values — never commit .env
# ──────────────────────────────────────────────────

# LLM Provider — OpenRouter API key
OPENROUTER_API_KEY=sk-or-v1-...

# Hermes/LiteLLM master key
# Used by Open WebUI and n8n to authenticate against Hermes Agent
# Generate: openssl rand -hex 24
LITELLM_MASTER_KEY=sk-hermes-changeme

# Open WebUI authentication (set false to disable for internal use only)
WEBUI_AUTH=true

# OpenClaw
# Replace with actual image path when available
OPENCLAW_IMAGE=ghcr.io/aia2025/openclaw:latest
OPENCLAW_WHATSAPP_TOKEN=
OPENCLAW_TELEGRAM_TOKEN=
OPENCLAW_WEBHOOK_SECRET=
