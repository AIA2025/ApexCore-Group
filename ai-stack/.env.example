# ai-stack/.env.example
# Copy to ai-stack/.env and fill in values.
# NEVER commit .env — it is excluded by .gitignore.
# ──────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────
# OpenRouter API key (required)
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# ── Hermes Agent (LiteLLM) ────────────────────────
# Master key used by open-webui, hermes-webui, and n8n to authenticate against hermes-agent.
# Generate: openssl rand -hex 24
# Must match LITELLM_MASTER_KEY in automation-stack/.env
LITELLM_MASTER_KEY=sk-hermes-REPLACE_ME

# ── Open WebUI ────────────────────────────────────
# Set to false only for fully private/trusted networks
WEBUI_AUTH=true

# ── OpenClaw ──────────────────────────────────────
# Set the actual image path before enabling the ops profile.
# Profile: docker compose --profile ops up -d
OPENCLAW_IMAGE=ghcr.io/aia2025/openclaw:latest
# Messenger credentials (set when real image is available)
OPENCLAW_WHATSAPP_TOKEN=
OPENCLAW_TELEGRAM_TOKEN=
OPENCLAW_WEBHOOK_SECRET=
