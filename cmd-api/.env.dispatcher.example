# ApexCore Hermes Dispatcher — Environment Variables
# Copy to /srv/apexcore/cmd-api/.env.dispatcher and fill in real values
# Generate tokens: openssl rand -hex 24

# ── Required ────────────────────────────────────────────────────────────────
DISPATCHER_TOKEN=your-dispatcher-token-here
LITELLM_MASTER_KEY=sk-hermes-your-key-here

# ── Optional (defaults shown) ────────────────────────────────────────────────
DISPATCHER_PORT=7071
HERMES_API_URL=http://hermes-agent:4000/v1/chat/completions
N8N_TASK_WEBHOOK=https://n8n.apexcore.group/webhook/task
N8N_LOG_WEBHOOK=https://n8n.apexcore.group/webhook/log
OPENCLAW_API_URL=http://openclaw:8000/send
CMD_API_URL=http://localhost:7070/status
CMD_TOKEN=your-cmd-api-token-here
