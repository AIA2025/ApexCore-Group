# ApexCore — Caddy Reverse Proxy
# Pfad auf VPS: /opt/openclaw/reverse-proxy/Caddyfile
# TLS: automatisch via Let's Encrypt (Produktion)
# VORAUSSETZUNG: DNS A-Records für alle Subdomains auf 76.13.138.73

{
    email oc@apexcore.group
}

# ─── OpenClaw ──────────────────────────────────────────────────────────────
oc.apexcore.group {
    handle /n8n/* {
        uri strip_prefix /n8n
        reverse_proxy 127.0.0.1:5678
    }
    handle {
        reverse_proxy http://openclaw-fresh:56364 {
            header_up Host {http.request.host}
            header_up X-Real-IP {http.request.remote}
        }
    }
    encode gzip
}

oc-staging.apexcore.group {
    reverse_proxy http://openclaw-fresh:56364 {
        header_up Host {http.request.host}
        header_up X-Real-IP {http.request.remote}
        header_up X-Forwarded-For {http.request.remote}
    }
    encode gzip
}

# ─── ApexCore Services ─────────────────────────────────────────────────────
openwebui.apexcore.group {
    reverse_proxy 127.0.0.1:3000
    encode gzip
}

n8n.apexcore.group {
    reverse_proxy 127.0.0.1:5678 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
    encode gzip
}

hermes.apexcore.group {
    reverse_proxy 127.0.0.1:32772
    encode gzip
}

paperclip.apexcore.group {
    reverse_proxy 127.0.0.1:52309
    encode gzip
}

dashboard.apexcore.group {
    reverse_proxy 127.0.0.1:9090
    encode gzip
}
